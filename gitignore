*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ── ZIP & Archive Files ──
*.zip
*.rar
*.tar
*.gz
*.7z

# ── Log Files ──
*.log
logs/

# ── Large Media (optional — remove if you want images tracked) ──
# *.mp4
# *.mov
