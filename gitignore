# ── Windows System Files ──
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── macOS System Files ──
.DS_Store
.AppleDouble
.LSOverride
._*

# ── VS Code Editor ──
.vscode/
*.code-workspace

# ── Node / npm (if used later) ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

